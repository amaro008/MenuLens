{
  "rewrites": [
    { "source": "/",                        "destination": "/src/pages/login.html" },
    { "source": "/login",                   "destination": "/src/pages/login.html" },
    { "source": "/login.html",              "destination": "/src/pages/login.html" },
    { "source": "/dashboard",               "destination": "/src/pages/dashboard.html" },
    { "source": "/dashboard.html",          "destination": "/src/pages/dashboard.html" },
    { "source": "/analyzer",                "destination": "/src/pages/analyzer.html" },
    { "source": "/analyzer.html",           "destination": "/src/pages/analyzer.html" },
    { "source": "/results",                 "destination": "/src/pages/results.html" },
    { "source": "/results.html",            "destination": "/src/pages/results.html" },
    { "source": "/history",                 "destination": "/src/pages/history.html" },
    { "source": "/history.html",            "destination": "/src/pages/history.html" },
    { "source": "/admin-kpi.html",          "destination": "/src/pages/admin-kpi.html" },
    { "source": "/admin-users.html",        "destination": "/src/pages/admin-users.html" },
    { "source": "/admin-config.html",       "destination": "/src/pages/admin-config.html" },
    { "source": "/admin",                   "destination": "/src/pages/admin-kpi.html" },
    { "source": "/admin/kpi",               "destination": "/src/pages/admin-kpi.html" },
    { "source": "/admin/users",             "destination": "/src/pages/admin-users.html" },
    { "source": "/admin/config",            "destination": "/src/pages/admin-config.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection",       "value": "1; mode=block" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
